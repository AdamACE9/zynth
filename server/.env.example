# Copy this file to server/.env and fill in your key. server/.env is gitignored.

# Your Google Gemini API key (https://aistudio.google.com/apikey).
# If left blank, the agent orchestrator runs in deterministic STUB mode so the
# rest of the app still works without burning credits.
GEMINI_API_KEY=

# Which Gemini model every runtime agent call uses (primary provider).
# Real options: gemini-2.5-flash (stable default) or gemini-3.6-flash (newest/cheapest).
GEMINI_MODEL=gemini-2.5-flash

# Groq — used ONLY for free-response quiz grading (Adam-approved second
# provider; overrides the single-provider note in TASKBRIEFING section 4).
# If left blank, free-response grading falls back to a deterministic stub.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# HTTP + Socket.io port for the backend.
PORT=3001

# Where the frontend dev server runs (for CORS).
CLIENT_ORIGIN=http://localhost:5173

# SQLite file location (relative to server/). Gitignored.
DATABASE_PATH=./data/zynth.sqlite
